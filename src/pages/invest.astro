---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

interface Article {
  slug: string;
  title: string;
  desc: string;
  date: string;
  readTime: string;
  tag: string;
}

const investArticles: Article[] = [
  { slug: 'tou-zi-ben-zhi-qi-ye-xian-jin-liu', title: '投资的本质就是投资企业未来现金流', desc: '买股票就是买公司，买公司就是买其未来现金流的折现。个人投资专栏的开篇，也是整个投资体系的基石信念。', date: '2026-05-30', readTime: '约 15 分钟阅读', tag: '个人投资' },
];

const methodologyArticles: Article[] = [
  { slug: 'impossible-triangle', title: '不可能铁三角与战略分层定价：华为思路对投资的启示', desc: '质量、成本、低价不可兼得。华为的解法不是三选二，而是市场分层。对基础设施投资的启示。', date: '2026-05-12', readTime: '约 5 分钟阅读', tag: '投资方法论' },
  { slug: 'zu-he-tou-zi-yin-zi-tou-zi', title: '组合投资和因子投资对房地产投资策略的启示', desc: '经典投资策略能否应用到房地产投资决策？', date: '2020-07-28', readTime: '约 8 分钟阅读', tag: '投资方法论' },
];

const allArticles = [...investArticles, ...methodologyArticles];
---

<BaseLayout title="投资学习" description="个人投资方法、学习心得与实践记录 — 建立自己的投资体系" wide>
  <!-- Hero -->
  <section class="invest-hero">
    <div class="invest-hero-badge">新专栏</div>
    <h1 class="invest-hero-title">个人投资学习笔记</h1>
    <p class="invest-hero-desc">
      从张潇雨的个人投资课出发，记录学习心得、投资实践与体系构建的过程。<br/>
      这不是投资建议，而是一个学习者构建自己投资体系的真实记录。
    </p>
    <div class="invest-hero-stats">
      <span class="stat-item">
        <span class="stat-num">3</span>
        <span class="stat-label">学习阶段</span>
      </span>
      <span class="stat-dot"></span>
      <span class="stat-item">
        <span class="stat-num">{allArticles.length}</span>
        <span class="stat-label">相关文章</span>
      </span>
      <span class="stat-dot"></span>
      <span class="stat-item">
        <span class="stat-num">持续</span>
        <span class="stat-label">更新迭代</span>
      </span>
    </div>
  </section>

  <!-- Why this column -->
  <section class="section">
    <h2 class="section-title">为什么要开这个专栏？</h2>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">📚</div>
        <h3>系统化学习</h3>
        <p>把付费课程的知识消化成自己的理解，而不是听完就忘。每篇笔记都是一次深度加工。</p>
      </div>
      <div class="why-card">
        <div class="why-icon">✍️</div>
        <h3>输出倒逼输入</h3>
        <p>写下来才能真理解。把隐性的直觉变成显性的原则，让每一次投资决策都有据可循。</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🔄</div>
        <h3>持续迭代</h3>
        <p>投资体系不是一蹴而就的。通过实践→复盘→修正的循环，不断逼近适合自己的方法。</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🌱</div>
        <h3>开放进化</h3>
        <p>不只依赖一门课。持续吸收经典书籍、优秀投资者的思考，让体系在碰撞中成长。</p>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section">
    <h2 class="section-title">学习路线图</h2>
    <div class="roadmap">
      <!-- Phase 1 -->
      <div class="phase">
        <div class="phase-header">
          <span class="phase-num">01</span>
          <div class="phase-info">
            <h3>学习笔记</h3>
            <p class="phase-desc">跟随课程模块，系统梳理核心概念与投资框架</p>
          </div>
          <span class="phase-status in-progress">进行中</span>
        </div>
        <div class="phase-modules">
          <div class="module">
            <span class="module-dot"></span>
            <div>
              <strong>导论：重新认识自己</strong>
              <p>普通投资者的优势与劣势</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot"></span>
            <div>
              <strong>市场规律</strong>
              <p>多元分散、择时陷阱、宏观迷信、风险度量、海外配置</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot"></span>
            <div>
              <strong>投资工具</strong>
              <p>指数基金、安全边际、抄底哲学、主动管理、交易成本</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot"></span>
            <div>
              <strong>自我局限</strong>
              <p>过度自信、反向复利、利益错位、场外因素、五大原则</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot"></span>
            <div>
              <strong>投资组合构建</strong>
              <p>永久组合 / 全天候 / 斯文森 / 因子投资</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot"></span>
            <div>
              <strong>实战工具箱</strong>
              <p>再平衡、四笔钱、网格交易、情景预案、非对称收益</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Phase 2 -->
      <div class="phase-connector"></div>
      <div class="phase">
        <div class="phase-header">
          <span class="phase-num">02</span>
          <div class="phase-info">
            <h3>实践记录</h3>
            <p class="phase-desc">真金白银的操作记录与决策复盘</p>
          </div>
          <span class="phase-status pending">待开始</span>
        </div>
        <div class="phase-modules">
          <div class="module">
            <span class="module-dot muted"></span>
            <div>
              <strong>投资组合构建</strong>
              <p>根据所学策略建立个人投资组合</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot muted"></span>
            <div>
              <strong>定投记录与反思</strong>
              <p>每季度操作记录与心理状态复盘</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot muted"></span>
            <div>
              <strong>重大决策复盘</strong>
              <p>用写作记录法记录每次交易的决策逻辑</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Phase 3 -->
      <div class="phase-connector"></div>
      <div class="phase">
        <div class="phase-header">
          <span class="phase-num">03</span>
          <div class="phase-info">
            <h3>体系构建与迭代</h3>
            <p class="phase-desc">融合多源思想，形成自己的投资原则</p>
          </div>
          <span class="phase-status pending">待开始</span>
        </div>
        <div class="phase-modules">
          <div class="module">
            <span class="module-dot muted"></span>
            <div>
              <strong>跨源整合</strong>
              <p>课程 + 经典书籍 + 优秀投资者的思想融合</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot muted"></span>
            <div>
              <strong>投资原则清单</strong>
              <p>形成自己版本的投资检查清单</p>
            </div>
          </div>
          <div class="module">
            <span class="module-dot muted"></span>
            <div>
              <strong>年度回顾与修正</strong>
              <p>每年审视体系的有效性，持续迭代</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Principles Preview -->
  <section class="section">
    <h2 class="section-title">课程核心原则</h2>
    <p style="margin-bottom: 1.5rem;">张潇雨个人投资课的五大原则，也是这个专栏的基石信念：</p>
    <div class="principles">
      <div class="principle-card">
        <span class="principle-num">1</span>
        <div>
          <strong>多元分散</strong>
          <p>没有任何人能预测哪类资产涨得最好。分散是唯一免费的午餐。</p>
        </div>
      </div>
      <div class="principle-card">
        <span class="principle-num">2</span>
        <div>
          <strong>被动为主</strong>
          <p>想长期打败市场极其困难。通过指数基金获得市场平均回报，长期更好。</p>
        </div>
      </div>
      <div class="principle-card">
        <span class="principle-num">3</span>
        <div>
          <strong>降低成本</strong>
          <p>每年省下的一点费用，长期复利下来对回报影响巨大。</p>
        </div>
      </div>
      <div class="principle-card">
        <span class="principle-num">4</span>
        <div>
          <strong>保持恒心</strong>
          <p>频繁买卖是收益最大的杀手。买入并持有，让时间发挥作用。</p>
        </div>
      </div>
      <div class="principle-card">
        <span class="principle-num">5</span>
        <div>
          <strong>不懂不做</strong>
          <p>只投自己真正理解的东西。如果说不清楚，就不要碰。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section class="section">
    <div class="section-head">
      <h2 class="section-title">相关文章</h2>
      <a href="/blog" class="section-link">全部文章 →</a>
    </div>
    {allArticles.length > 0 ? (
      <ul class="article-grid">
        {allArticles.map((a) => <ArticleCard {...a} />)}
      </ul>
    ) : (
      <div class="empty-state">
        <p>专栏刚刚起步，第一篇课程笔记正在路上。</p>
        <p class="empty-sub">学习笔记将在 <a href="/blog?category=个人投资">博客的个人投资分类</a> 下发布，敬请关注。</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* === Invest Hero === */
  .invest-hero {
    text-align: center;
    padding: 3rem 0 3.5rem;
    position: relative;
  }
  .invest-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    color: #b8860b;
    background: rgba(184, 134, 11, 0.1);
    border: 1px solid rgba(184, 134, 11, 0.25);
    padding: 0.2rem 0.7rem;
    border-radius: 12px;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }
  .invest-hero-title {
    font-size: 2.8rem;
    margin-bottom: 0.75rem;
  }
  .invest-hero-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }
  .invest-hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .stat-num {
    font-weight: 650;
    color: var(--text);
    font-size: 1rem;
  }
  .stat-label {
    font-size: 0.78rem;
  }
  .stat-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  /* === Section === */
  .section {
    margin-bottom: 3.5rem;
  }
  .section-title {
    font-size: 1.5rem;
    font-weight: 650;
    margin: 0 0 0.2rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .section-link {
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* === Why Grid === */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
  }
  .why-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    transition: border-color 0.2s;
  }
  .why-card:hover {
    border-color: rgba(184, 134, 11, 0.3);
  }
  .why-icon {
    font-size: 1.5rem;
    margin-bottom: 0.6rem;
  }
  .why-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--text);
  }
  .why-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* === Roadmap === */
  .roadmap {
    margin-top: 1.5rem;
  }
  .phase {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .phase-connector {
    height: 24px;
    width: 2px;
    background: linear-gradient(to bottom, var(--border-light), transparent);
    margin-left: 2rem;
  }
  .phase-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .phase-num {
    font-size: 1.6rem;
    font-weight: 700;
    color: rgba(184, 134, 11, 0.3);
    line-height: 1;
    flex-shrink: 0;
    width: 36px;
  }
  .phase-info {
    flex: 1;
  }
  .phase-info h3 {
    font-size: 1.15rem;
    font-weight: 650;
    margin: 0 0 0.15rem;
    color: var(--text);
  }
  .phase-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }
  .phase-status {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.6rem;
    border-radius: 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .phase-status.in-progress {
    background: rgba(52, 199, 89, 0.1);
    color: #34c759;
    border: 1px solid rgba(52, 199, 89, 0.2);
  }
  .phase-status.pending {
    background: var(--bg-elevated);
    color: var(--text-muted);
    border: 1px solid var(--border-light);
  }
  .phase-modules {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-left: 2rem;
  }
  .module {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
  }
  .module-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 5px;
  }
  .module-dot.muted {
    background: var(--text-muted);
    opacity: 0.4;
  }
  .module strong {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .module p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0.1rem 0 0;
  }

  /* === Principles === */
  .principles {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .principle-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    transition: border-color 0.2s;
  }
  .principle-card:hover {
    border-color: rgba(184, 134, 11, 0.25);
  }
  .principle-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(184, 134, 11, 0.12);
    color: #b8860b;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .principle-card strong {
    font-size: 0.92rem;
  }
  .principle-card p {
    font-size: 0.83rem;
    color: var(--text-secondary);
    margin: 0.15rem 0 0;
    line-height: 1.45;
  }

  /* === Articles === */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--bg-card);
    border: 1px dashed var(--border-light);
    border-radius: var(--radius-card);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
  .empty-sub {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  /* === Responsive === */
  @media (max-width: 640px) {
    .invest-hero-title {
      font-size: 2rem;
    }
    .why-grid {
      grid-template-columns: 1fr;
    }
    .article-grid {
      grid-template-columns: 1fr;
    }
    .phase-modules {
      padding-left: 0;
    }
    .phase-num {
      display: none;
    }
  }
</style>
