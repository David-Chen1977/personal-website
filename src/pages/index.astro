---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getAllArticles, categories } from '../data/articles';

const sorted = getAllArticles();
const featured = sorted[0];
const rest = sorted.slice(0, 8);
---

<BaseLayout title="首页" description="算电协同 · AI 投资 · 投资方法论 — 专业内容与投资分析" wide>
  <!-- Hero -->
  <section class="hero">
    <p class="hero-label">陈道雷</p>
    <h1 class="hero-title">算电协同 · AI 投资 · 投资方法论</h1>
    <p class="hero-desc">算电协同、AI 应用层投资、结构化数据基础模型、投资方法论的<br class="hide-mobile"/>深度分析与框架沉淀。记录专业思考，构建可复用体系。</p>
    <div class="hero-stats">
      <span class="hero-stat"><span class="stat-num">{sorted.length}</span> 篇文章</span>
      <span class="stat-dot"></span>
      <span class="hero-stat"><span class="stat-num">{categories.length}</span> 个主题</span>
      <span class="stat-dot"></span>
      <span class="hero-stat">持续更新中</span>
    </div>
  </section>

  <!-- Featured Article -->
  <section class="section">
    <div class="section-head">
      <h2>最新文章</h2>
      <a href="/blog" class="section-link">查看全部 →</a>
    </div>
    <a href={`/blog/${featured.slug}`} class="featured-card">
      <span class="featured-category">{featured.category}</span>
      <h3 class="featured-title">{featured.title}</h3>
      <p class="featured-desc">{featured.desc}</p>
      <span class="featured-meta">{featured.date} · {featured.readTime}</span>
    </a>
  </section>

  <!-- Investment Column -->
  <section class="section">
    <div class="section-head">
      <h2>📈 个人投资学习</h2>
      <a href="/invest" class="section-link">专栏首页 →</a>
    </div>
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <a href="/blog/tou-zi-ben-zhi-qi-ye-xian-jin-liu" class="featured-card" style="background: linear-gradient(135deg, rgba(184,134,11,0.08), var(--bg-card)); border-color: rgba(184,134,11,0.2);">
        <span class="featured-tag" style="color: #b8860b;">专栏开篇</span>
        <h3 class="featured-title">投资的本质就是投资企业未来现金流</h3>
        <p class="featured-desc">买股票就是买公司，买公司就是买其未来现金流的折现。从张潇雨、巴菲特到段永平，三位老师都指向同一个基石信念。</p>
        <span class="featured-meta">2026-05-30 · 约 15 分钟阅读</span>
      </a>
      <a href="/invest" class="invest-cta-card">
        <div class="invest-cta-body">
          <span class="invest-cta-badge">新开专栏</span>
          <h3 class="invest-cta-title">从零构建自己的投资体系</h3>
          <p class="invest-cta-desc">记录张潇雨个人投资课的学习心得、投资实践与体系构建过程。不是投资建议，而是一个学习者真实的成长记录。</p>
          <div class="invest-cta-meta">
            <span>3 个学习阶段</span>
            <span>·</span>
            <span>持续更新中</span>
          </div>
        </div>
        <div class="invest-cta-arrow">→</div>
      </a>
    </div>
  </section>

  <!-- Rest of Articles -->
  <section class="section">
    <ul class="article-grid">
      {rest.slice(0, 6).map((a) => (
        <ArticleCard {...a} />
      ))}
    </ul>
    {sorted.length > 7 && (
      <div class="more-wrap">
        <a href="/blog" class="more-link">浏览全部 {sorted.length} 篇文章 →</a>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* === Hero Section === */
  .hero {
    text-align: center;
    padding: 3.5rem 0 4rem;
    position: relative;
  }
  .hero-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
  .stat-num {
    font-weight: 650;
    color: var(--text);
  }
  .stat-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.4;
  }

  /* === Section === */
  .section {
    margin-bottom: 3.5rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .section-head h2 {
    margin: 0;
    font-size: 1.4rem;
  }
  .section-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }
  .section-link:hover {
    color: var(--accent);
  }

  /* === Featured Card === */
  .featured-card {
    display: block;
    background: linear-gradient(135deg, var(--accent-bg), var(--bg-card));
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border));
    border-radius: var(--radius-card);
    padding: 1.75rem 2rem;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .featured-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 3px; height: 100%;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
  }
  .featured-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    border-color: var(--accent);
    text-decoration: none;
  }
  .featured-tag {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .featured-title {
    font-size: 1.3rem;
    font-weight: 650;
    color: var(--text);
    margin: 0.5rem 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }
  .featured-card:hover .featured-title {
    color: var(--accent);
  }
  .featured-desc {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }
  .featured-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* === Article Grid === */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 0;
    list-style: none;
  }

  .more-wrap {
    text-align: center;
    margin-top: 1.5rem;
  }
  .more-link {
    display: inline-block;
    font-size: 0.88rem;
    color: var(--accent);
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    transition: all 0.2s;
  }
  .more-link:hover {
    background: var(--accent-bg);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero { padding: 2rem 0 2.5rem; }
    .hero-title { font-size: 2rem; }
    .hero-desc { font-size: 1rem; }
    .hero-desc br.hide-mobile { display: none; }
    .article-grid { grid-template-columns: 1fr; }
    .featured-card { padding: 1.25rem 1.5rem; }
  }
</style>
