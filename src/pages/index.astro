---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = [
  { slug: 'huihong-ppt-dev-journey', title: 'HUIIHONG PPT 模版开发：从AI协作到可复用技能的全记录', desc: '十轮迭代从测量模版到 Pillow 自绘图标，最终封装为 OpenCode 可复用技能的完整过程。', date: '2026-05-29', readTime: '约 10 分钟阅读', tag: 'AI 协作' },
  { slug: 'suan-dian-xie-tong-AI', title: '算电协同：AI 下半场，电比芯片更稀缺', desc: '算力遇到电力瓶颈，中美两套体制给出完全不同的应对逻辑。三层投资优先级和六个商业模式拆解。', date: '2026-05-28', readTime: '约 10 分钟阅读', tag: '算电协同' },
  { slug: 'suan-dian-xie-tong-deep-analysis', title: '算电协同深度分析：当算力遇上电力的结构性机会', desc: '底层逻辑从"电随算动"到"算随电动"，五大落地模式与四条投资主线的全面拆解。', date: '2026-05-29', readTime: '约 12 分钟阅读', tag: '算电协同' },
  { slug: 'liu-zhang-wang-deep', title: '六张网规划实施方案深度解读：7万亿投资的底层逻辑', desc: '从政治局定调到发改委落地，六张网的投资逻辑、产业链拆解、多网协同效应与时间窗口。', date: '2026-05-25', readTime: '约 15 分钟阅读', tag: '政策解读' },
  { slug: 'liu-zhang-wang', title: '>7万亿！六张网同时开建，这波基建红利对普通人意味着什么？', desc: '政治局定调、发改委落地——六张网不是重复建设，是"组网"。七个投资方向和一个算电协同的单独机会。', date: '2026-05-22', readTime: '约 6 分钟阅读', tag: '政策解读' },
  { slug: 'suan-dian-xie-tong-2', title: '算电协同产业链拆解：利润池在哪里？', desc: '上游绿电供给、中游智算基建、下游算力服务——三层的利润分布、竞争格局和卡位策略。', date: '2026-05-18', readTime: '约 10 分钟阅读', tag: '算电协同' },
  { slug: 'suan-dian-xie-tong-1', title: '算电协同：为什么这是未来五年确定性很高的投资主题', desc: 'AI 算力集群用电已进入 500MW 级，算力正在成为新的电力需求。', date: '2026-05-15', readTime: '约 8 分钟阅读', tag: '算电协同' },
  { slug: 'dian-li-xian-huo-di-ceng-luo-ji', title: '电力现货交易底层逻辑及核心竞争力', desc: '五大维度拆解电力现货交易核心竞争力：预测能力、交易策略、风险管理、技术系统与资源整合。', date: '2025-08-11', readTime: '约 8 分钟阅读', tag: '电力交易' },
];
const featured = articles[0];
const rest = articles.slice(1);
---

<BaseLayout title="首页" description="算电协同 · 电力交易 · 新能源 — 专业内容与投资分析" wide>
  <!-- Hero -->
  <section class="hero">
    <p class="hero-label">陈道雷</p>
    <h1 class="hero-title">算电协同 · 电力交易 · 新能源</h1>
    <p class="hero-desc">算力与电力协同、电力市场改革、新能源基础设施投资的<br class="hide-mobile"/>深度分析与投资框架。记录专业思考，沉淀可复用框架。</p>
    <div class="hero-stats">
      <span class="hero-stat"><span class="stat-num">{articles.length}</span> 篇文章</span>
      <span class="stat-dot"></span>
      <span class="hero-stat"><span class="stat-num">8</span> 个主题</span>
      <span class="stat-dot"></span>
      <span class="hero-stat">持续更新中</span>
    </div>
  </section>

  <!-- Featured Article -->
  <section class="section">
    <div class="section-head">
      <h2>最新文章</h2>
      <a href="/blog" class="section-link">查看全部 →</a>
    </div>
    <a href={`/blog/${featured.slug}`} class="featured-card">
      <span class="featured-tag">{featured.tag}</span>
      <h3 class="featured-title">{featured.title}</h3>
      <p class="featured-desc">{featured.desc}</p>
      <span class="featured-meta">{featured.date} · {featured.readTime}</span>
    </a>
  </section>

  <!-- Investment Column -->
  <section class="section">
    <div class="section-head">
      <h2>📈 个人投资学习</h2>
      <a href="/invest" class="section-link">专栏首页 →</a>
    </div>
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <a href="/blog/tou-zi-ben-zhi-qi-ye-xian-jin-liu" class="featured-card" style="background: linear-gradient(135deg, rgba(184,134,11,0.08), var(--bg-card)); border-color: rgba(184,134,11,0.2);">
        <span class="featured-tag" style="color: #b8860b;">专栏开篇</span>
        <h3 class="featured-title">投资的本质就是投资企业未来现金流</h3>
        <p class="featured-desc">买股票就是买公司，买公司就是买其未来现金流的折现。从张潇雨、巴菲特到段永平，三位老师都指向同一个基石信念。</p>
        <span class="featured-meta">2026-05-30 · 约 15 分钟阅读</span>
      </a>
      <a href="/invest" class="invest-cta-card">
        <div class="invest-cta-body">
          <span class="invest-cta-badge">新开专栏</span>
          <h3 class="invest-cta-title">从零构建自己的投资体系</h3>
          <p class="invest-cta-desc">记录张潇雨个人投资课的学习心得、投资实践与体系构建过程。不是投资建议，而是一个学习者真实的成长记录。</p>
          <div class="invest-cta-meta">
            <span>3 个学习阶段</span>
            <span>·</span>
            <span>持续更新中</span>
          </div>
        </div>
        <div class="invest-cta-arrow">→</div>
      </a>
    </div>
  </section>

  <!-- Rest of Articles -->
  <section class="section">
    <ul class="article-grid">
      {rest.slice(0, 6).map((a) => (
        <ArticleCard {...a} />
      ))}
    </ul>
    {articles.length > 7 && (
      <div class="more-wrap">
        <a href="/blog" class="more-link">浏览全部 {articles.length} 篇文章 →</a>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* === Hero Section === */
  .hero {
    text-align: center;
    padding: 3.5rem 0 4rem;
    position: relative;
  }
  .hero-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
  .stat-num {
    font-weight: 650;
    color: var(--text);
  }
  .stat-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.4;
  }

  /* === Section === */
  .section {
    margin-bottom: 3.5rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .section-head h2 {
    margin: 0;
    font-size: 1.4rem;
  }
  .section-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }
  .section-link:hover {
    color: var(--accent);
  }

  /* === Featured Card === */
  .featured-card {
    display: block;
    background: linear-gradient(135deg, var(--accent-bg), var(--bg-card));
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border));
    border-radius: var(--radius-card);
    padding: 1.75rem 2rem;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .featured-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 3px; height: 100%;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
  }
  .featured-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    border-color: var(--accent);
    text-decoration: none;
  }
  .featured-tag {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .featured-title {
    font-size: 1.3rem;
    font-weight: 650;
    color: var(--text);
    margin: 0.5rem 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }
  .featured-card:hover .featured-title {
    color: var(--accent);
  }
  .featured-desc {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }
  .featured-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* === Article Grid === */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 0;
    list-style: none;
  }

  .more-wrap {
    text-align: center;
    margin-top: 1.5rem;
  }
  .more-link {
    display: inline-block;
    font-size: 0.88rem;
    color: var(--accent);
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    transition: all 0.2s;
  }
  .more-link:hover {
    background: var(--accent-bg);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero { padding: 2rem 0 2.5rem; }
    .hero-title { font-size: 2rem; }
    .hero-desc { font-size: 1rem; }
    .hero-desc br.hide-mobile { display: none; }
    .article-grid { grid-template-columns: 1fr; }
    .featured-card { padding: 1.25rem 1.5rem; }
  }
</style>
