---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles as allArticles, categories, getAllArticles } from '../data/articles';

const sorted = getAllArticles();
---

<BaseLayout title="文章" description="算电协同 · 电力交易 · 新能源 · 投资方法论" wide>
  <div class="page-head">
    <h1>文章</h1>
    <p class="page-desc">
      已发布 <strong>{sorted.length}</strong> 篇文章，覆盖 <strong>{categories.length}</strong> 个主题。
    </p>
  </div>

  <div class="filter-bar" id="filterBar">
    <button class="filter-btn active" data-filter="all">全部</button>
    {categories.map((cat) => (
      <button class="filter-btn" data-filter={cat}>{cat}</button>
    ))}
    <div class="filter-spacer"></div>
    <a href="/blog/tags" class="filter-tags-link">标签云 →</a>
  </div>

  <div class="article-list" id="articleList">
    {sorted.map((a) => (
      <article class="article-row" data-category={a.category}>
        <a href={`/blog/${a.slug}`} class="row-link">
          <div class="row-body">
            <div class="row-category">{a.category}</div>
            <h3 class="row-title">{a.title}</h3>
            <p class="row-desc">{a.desc}</p>
            <div class="row-meta">{a.date} · {a.readTime}</div>
          </div>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: 2rem;
  }
  .page-head h1 {
    margin-bottom: 0.4rem;
  }
  .page-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .filter-bar {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-light);
  }
  .filter-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 0.3rem 0.75rem;
    border-radius: 16px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover {
    color: var(--text);
    background: var(--bg-elevated);
  }
  .filter-btn.active {
    background: var(--accent);
    color: #fff;
  }
  .filter-spacer {
    flex: 1;
    min-width: 0.5rem;
  }
  .filter-tags-link {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    border-radius: 16px;
    transition: all 0.2s;
  }
  .filter-tags-link:hover {
    color: var(--accent);
    background: var(--accent-bg);
    text-decoration: none;
  }

  .article-list {
    display: flex;
    flex-direction: column;
  }
  .article-row {
    border-bottom: 1px solid var(--border-light);
    transition: background 0.15s;
  }
  .article-row:last-child {
    border-bottom: none;
  }
  .article-row:hover {
    background: var(--bg-elevated);
    border-radius: 6px;
    margin: 0 -0.75rem;
    padding: 0 0.75rem;
  }
  .row-link {
    display: block;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
  }
  .row-link:hover { text-decoration: none; }

  .row-category {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .row-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.3rem;
    line-height: 1.35;
    transition: color 0.15s;
  }
  .article-row:hover .row-title {
    color: var(--accent);
  }
  .row-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.45;
    margin: 0 0 0.3rem;
  }
  .row-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .article-row.hidden {
    display: none;
  }
</style>

<script>
  (function() {
    var bar = document.getElementById('filterBar');
    var articles = document.querySelectorAll('.article-row');

    // Support ?category=XXX from URL
    var params = new URLSearchParams(window.location.search);
    var initialCategory = params.get('category');
    if (initialCategory) {
      var targetBtn = bar.querySelector('[data-filter="' + initialCategory + '"]');
      if (targetBtn) {
        bar.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        targetBtn.classList.add('active');
        articles.forEach(function(a) {
          a.classList.toggle('hidden', a.getAttribute('data-category') !== initialCategory);
        });
      }
    }

    bar.addEventListener('click', function(e) {
      var btn = e.target.closest('.filter-btn');
      if (!btn) return;

      bar.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');

      var filter = btn.getAttribute('data-filter');
      articles.forEach(function(a) {
        a.classList.toggle('hidden', filter !== 'all' && a.getAttribute('data-category') !== filter);
      });
    });
  })();
</script>

