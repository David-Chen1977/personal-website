      <td>中</td>
      <td>⭐⭐⭐</td>
    </tr>
    <tr>
      <td>高效供电配电</td>
      <td>20-30%</td>
      <td>中</td>
      <td>⭐⭐</td>
    </tr>
    <tr>
      <td>储能系统</td>
      <td>15-25%</td>
      <td>高</td>
      <td>⭐⭐</td>
    </tr>
    <tr>
      <td>智算中心运营</td>
      <td>30-50%</td>
      <td>极高</td>
      <td>⭐⭐⭐</td>
    </tr>
    <tr>
      <td><strong>能效优化服务</strong></td>
