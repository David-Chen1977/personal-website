---
export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || '个人专业网站 — 算电协同 · 电力交易 · 新能源'} />
    <meta property="og:title" content={`${title} | 陈道雷`} />
    <meta property="og:description" content={description || '算力与电力协同、电力市场改革、新能源基础设施投资的深度分析与投资框架。'} />
    <meta property="og:type" content={currentPath.startsWith('/blog/') ? 'article' : 'website'} />
    <meta property="og:url" content={`https://chendaolei.us.kg${currentPath}`} />
    <meta property="og:site_name" content="陈道雷" />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | 陈道雷`} />
    <meta name="twitter:description" content={description || '算力与电力协同、电力市场改革、新能源基础设施投资的深度分析与投资框架。'} />
    <link rel="alternate" type="application/rss+xml" title="陈道雷 | RSS Feed" href="/rss.xml" />
    <title>{title} | 陈道雷</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      // 自托管访问统计 (via Cloudflare Worker + KV)
      (function() {
        var p = location.pathname;
        if (p.startsWith('/search') || p.startsWith('/pagefind')) return;
        new Image().src = '/track?path=' + encodeURIComponent(p);
      })();
    </script>
    <style>
      /* ============================================
         Design System v2 — Light & Dark Modes
         ============================================ */

      /* === Light Mode (default) === */
      :root {
        --color-bg: #f4f5f9;
        --color-bg-card: #ffffff;
        --color-bg-elevated: #fafafe;
        --color-text: #181826;
        --color-text-secondary: #44445a;
        --color-text-muted: #8888a0;
        --color-primary: #1e3a5f;
        --color-primary-light: #2d5a8a;
        --color-accent: #0d9488;
        --color-accent-light: #14b8a6;
        --color-accent-bg: #f0fdfa;
        --color-border: #e2e2ea;
        --color-border-light: #eeedf2;
        --color-nav-bg: rgba(244, 245, 249, 0.88);
        --color-hero-decor: #0d9488;
        --color-inline-code-bg: #edeef2;
        --color-toc-bg: #edeef2;
        --color-table-header: #edeef2;
        --color-table-stripe: #f8f8fa;

        --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        --shadow-card: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.03);
        --shadow-card-hover: 0 4px 14px rgba(0,0,0,0.06), 0 2px 4px rgba(0,0,0,0.04);
        --shadow-elevated: 0 8px 30px rgba(0,0,0,0.06);

        --radius-sm: 6px;
        --radius-card: 12px;
        --radius-lg: 16px;

        --max-width-content: 720px;
        --max-width-wide: 800px;

        font-synthesis: none;
        text-rendering: optimizeLegibility;
      }

      /* === Dark Mode === */
      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #0c0c16;
          --color-bg-card: #161622;
          --color-bg-elevated: #1a1a28;
          --color-text: #e2e2ea;
          --color-text-secondary: #9a9aae;
          --color-text-muted: #6a6a7e;
          --color-primary: #6ba3d4;
          --color-primary-light: #7fc0f0;
          --color-accent: #34d399;
          --color-accent-light: #5eead4;
          --color-accent-bg: rgba(52, 211, 153, 0.08);
          --color-border: #1e1e2e;
          --color-border-light: #26263a;
          --color-nav-bg: rgba(12, 12, 22, 0.88);
          --color-hero-decor: #34d399;
          --color-inline-code-bg: #1e1e2e;
          --color-toc-bg: #1a1a28;
          --color-table-header: #1a1a28;
          --color-table-stripe: #12121e;

          --shadow-sm: 0 1px 2px rgba(0,0,0,0.2);
          --shadow-card: 0 1px 3px rgba(0,0,0,0.25), 0 1px 2px rgba(0,0,0,0.15);
          --shadow-card-hover: 0 4px 14px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2);
          --shadow-elevated: 0 8px 30px rgba(0,0,0,0.35);
        }
      }

      /* === Manual Dark Mode Toggle === */
      html.dark {
        --color-bg: #0c0c16;
        --color-bg-card: #161622;
        --color-bg-elevated: #1a1a28;
        --color-text: #e2e2ea;
        --color-text-secondary: #9a9aae;
        --color-text-muted: #6a6a7e;
        --color-primary: #6ba3d4;
        --color-primary-light: #7fc0f0;
        --color-accent: #34d399;
        --color-accent-light: #5eead4;
        --color-accent-bg: rgba(52, 211, 153, 0.08);
        --color-border: #1e1e2e;
        --color-border-light: #26263a;
        --color-nav-bg: rgba(12, 12, 22, 0.88);
        --color-hero-decor: #34d399;
        --color-inline-code-bg: #1e1e2e;
        --color-toc-bg: #1a1a28;
        --color-table-header: #1a1a28;
        --color-table-stripe: #12121e;

        --shadow-sm: 0 1px 2px rgba(0,0,0,0.2);
        --shadow-card: 0 1px 3px rgba(0,0,0,0.25), 0 1px 2px rgba(0,0,0,0.15);
        --shadow-card-hover: 0 4px 14px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2);
        --shadow-elevated: 0 8px 30px rgba(0,0,0,0.35);
      }

      /* === Reset & Base === */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 18px; scroll-behavior: smooth; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-image:
          radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--color-accent) 4%, transparent) 0%, transparent 60%),
          repeating-linear-gradient(0deg, transparent, transparent 40px, var(--color-border-light) 40px, var(--color-border-light) 40.5px, transparent 40.5px, transparent 80px);
        background-attachment: fixed;
        min-height: 100vh;
        transition: background 0.3s, color 0.3s;
      }

      /* === Reading Progress Bar === */
      #reading-progress {
        position: fixed; top: 0; left: 0; height: 3px;
        background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light));
        z-index: 200;
        width: 0%;
        transition: width 0.05s linear;
        pointer-events: none;
      }

      /* === Navigation === */
      nav {
        position: sticky; top: 0; z-index: 100;
        background: var(--color-nav-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--color-border);
        transition: background 0.3s;
      }
      nav .inner {
        max-width: var(--max-width-wide); margin: 0 auto;
        display: flex; align-items: center; gap: 0.5rem;
        padding: 0 1.5rem; height: 56px;
      }
      nav .logo {
        font-weight: 750; font-size: 1.1rem;
        color: var(--color-text); text-decoration: none;
        letter-spacing: -0.02em;
        transition: opacity 0.2s, color 0.2s;
      }
      nav .logo:hover { opacity: 0.7; }
      nav .links { display: flex; gap: 1.5rem; align-items: center; }
      nav .spacer { flex: 1; }
      nav .links a {
        text-decoration: none; color: var(--color-text-muted);
        font-size: 0.9rem; font-weight: 500;
        position: relative; padding: 0.25rem 0;
        transition: color 0.2s;
      }
      nav .links a:hover { color: var(--color-accent); }
      nav .links a.active { color: var(--color-accent); }
      nav .links a.active::after {
        content: '';
        position: absolute; bottom: -2px; left: 0; right: 0;
        height: 2px; background: var(--color-accent);
        border-radius: 1px;
      }

      /* === Search Button === */
      .search-btn {
        background: none; border: 1px solid var(--color-border);
        border-radius: 6px;
        width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: var(--color-text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.2s;
        line-height: 1;
      }
      .search-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-accent-bg);
        text-decoration: none;
      }

      /* === Dark Mode Toggle === */
      .theme-toggle {
        background: none; border: 1px solid var(--color-border);
        border-radius: 6px;
        width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: var(--color-text-muted);
        font-size: 1rem;
        transition: all 0.2s;
        margin-left: 0.75rem;
        line-height: 1;
        padding: 0;
      }
      .theme-toggle:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-accent-bg);
      }
      .theme-toggle .icon-light,
      .theme-toggle .icon-dark {
        transition: opacity 0.2s, transform 0.2s;
      }
      html.dark .theme-toggle .icon-light,
      .theme-toggle .icon-dark { display: none; }
      html.dark .theme-toggle .icon-dark { display: inline; }

      /* === Main Content === */
      main {
        max-width: var(--max-width-content); margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
      }

      /* === Typography === */
      h1 { font-size: 2.2rem; font-weight: 750; line-height: 1.25; letter-spacing: -0.03em; margin-bottom: 0.5rem; color: var(--color-primary); }
      h2 { font-size: 1.5rem; font-weight: 650; line-height: 1.3; margin-top: 2.5rem; margin-bottom: 0.75rem; color: var(--color-text); }
      h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.75rem; margin-bottom: 0.5rem; color: var(--color-text); }
      h2 a.anchor, h3 a.anchor {
        text-decoration: none; color: var(--color-accent);
        opacity: 0; transition: opacity 0.15s;
        font-weight: 400; margin-left: 0.25rem;
      }
      h2:hover a.anchor, h3:hover a.anchor { opacity: 1; }
      p { margin-bottom: 1.2rem; }
      p, li { color: var(--color-text-secondary); }

      a { color: var(--color-accent); text-decoration: none; transition: color 0.15s; }
      a:hover { color: var(--color-accent-light); text-decoration: underline; }

      ::selection {
        background: var(--color-accent);
        color: #fff;
      }

      ul, ol { padding-left: 1.25rem; margin-bottom: 1.2rem; }
      li { margin-bottom: 0.3rem; }

      blockquote {
        border-left: 3px solid var(--color-accent);
        padding: 0.75rem 1rem;
        margin: 1.5rem 0;
        background: var(--color-accent-bg);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        color: var(--color-text-secondary);
        font-style: normal;
      }
      blockquote p { margin-bottom: 0; }

      hr {
        border: none; border-top: 1px solid var(--color-border);
        margin: 2.5rem 0;
      }

      /* === Code === */
      code {
        font-family: "SF Mono", "Fira Code", "JetBrains Mono", monospace;
        font-size: 0.85rem;
        background: var(--color-inline-code-bg);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        color: var(--color-text);
      }
      pre {
        background: var(--color-bg-elevated);
        color: var(--color-text);
        border: 1px solid var(--color-border);
        padding: 1rem 1.25rem; border-radius: 8px;
        overflow-x: auto; margin: 1.5rem 0;
        font-size: 0.82rem;
        line-height: 1.5;
        position: relative;
      }
      pre code {
        background: none; padding: 0; color: inherit;
        font-size: inherit;
      }

      /* === Tables === */
      table {
        width: 100%; border-collapse: collapse;
        margin: 1.5rem 0; font-size: 0.9rem;
      }
      th, td {
        border: 1px solid var(--color-border);
        padding: 0.5rem 0.75rem; text-align: left;
      }
      th { background: var(--color-table-header); font-weight: 600; color: var(--color-text); }
      tr:nth-child(even) { background: var(--color-table-stripe); }

      /* === Article Meta === */
      .article-meta {
        font-size: 0.85rem; color: var(--color-text-muted);
        margin-bottom: 2rem;
        display: flex; gap: 1rem; flex-wrap: wrap;
      }
      .article-meta span { display: inline-flex; align-items: center; gap: 0.3rem; }

      /* === Tags === */
      .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
      .tag {
        background: var(--color-accent-bg); color: var(--color-accent);
        padding: 0.15rem 0.7rem; border-radius: 12px;
        font-size: 0.78rem; font-weight: 500;
        border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
      }

      /* === Back link === */
      .back-link {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 2rem;
      }
      .back-link:hover { color: var(--color-accent); text-decoration: none; }

      /* === Footer === */
      footer {
        border-top: 1px solid var(--color-border);
        padding: 2.5rem 1.5rem;
        text-align: center;
        color: var(--color-text-muted); font-size: 0.82rem;
        transition: border-color 0.3s;
      }
      footer a { color: var(--color-text-muted); }
      footer a:hover { color: var(--color-accent); }

      /* === Responsive === */
      @media (max-width: 640px) {
        html { font-size: 16px; }
        main { padding: 2rem 1.25rem 4rem; }
        h1 { font-size: 1.8rem; }
        h2 { font-size: 1.3rem; }
        nav .inner { padding: 0 1rem; }
        nav .links { gap: 1rem; }
        .article-card-grid { grid-template-columns: 1fr; }
      }

      /* === Homepage Hero === */
      .hero {
        margin-bottom: 3rem;
        position: relative;
      }
      .hero-bg-decor {
        position: absolute;
        top: -40px; right: -40px;
        width: 260px; height: 260px;
        pointer-events: none;
        z-index: 0;
        color: var(--color-hero-decor);
        transition: color 0.3s;
      }
      .hero-bg-decor svg { width: 100%; height: 100%; }
      .hero-content { position: relative; z-index: 1; }
      .hero h1 { font-size: 2.5rem; margin-bottom: 0.75rem; color: var(--color-primary); }
      .hero .subtitle {
        font-size: 1.1rem; color: var(--color-text-secondary);
        line-height: 1.6; margin-bottom: 1.5rem;
        max-width: 580px;
      }
      .hero .subtitle strong { color: var(--color-text); }
      .hero .cta {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--color-primary); color: #fff;
        padding: 0.6rem 1.5rem; border-radius: 8px;
        font-size: 0.9rem; font-weight: 600;
        text-decoration: none; transition: all 0.2s;
      }
      .hero .cta:hover { background: var(--color-accent); text-decoration: none; transform: translateY(-1px); }

      /* === Category Heading === */
      .category-heading {
        font-size: 1rem; font-weight: 650;
        color: var(--color-accent);
        margin-top: 2rem; margin-bottom: 0.75rem;
        display: flex; align-items: center; gap: 0.5rem;
      }
      .category-heading::after {
        content: '';
        flex: 1; height: 1px;
        background: linear-gradient(90deg, var(--color-accent), transparent);
        opacity: 0.3;
      }
    </style>
  </head>
  <body>
    <script>
      // Dark mode initialization (before paint to avoid flash)
      (function() {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    {currentPath.startsWith('/blog/') && <div id="reading-progress"></div>}
    <nav>
      <div class="inner">
        <a href="/" class="logo">陈道雷</a>
        <div class="spacer"></div>
        <div class="links">
          <a href="/" class={currentPath === '/' ? 'active' : ''}>首页</a>
          <a href="/about" class={currentPath === '/about' ? 'active' : ''}>关于</a>
          <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>文章</a>
          <a href="/projects" class={currentPath === '/projects' ? 'active' : ''}>作品</a>
        </div>
        <a href="/search" class="search-btn" aria-label="搜索">🔍</a>
        <button class="theme-toggle" id="themeToggle" aria-label="切换暗色模式">
          <span class="icon-light">☀</span>
          <span class="icon-dark">☾</span>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} 陈道雷 · 用 ❤ 和 ⚡ 构建</p>
      <p style="margin-top: 0.3rem;">
        <a href="/rss.xml" target="_blank" rel="noopener">RSS</a>
        · <a href="https://cloudflare.com" target="_blank" rel="noopener">Cloudflare Pages</a>
        · <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
      </p>
    </footer>

    <script>
      // Theme toggle
      document.getElementById('themeToggle')?.addEventListener('click', function() {
        var html = document.documentElement;
        var isDark = html.classList.contains('dark');
        if (isDark) {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      });

      // Reading progress + TOC (blog pages)
      {currentPath.startsWith('/blog/') && (
        function() {
          // Reading progress bar
          var bar = document.getElementById('reading-progress');
          if (bar) {
            var winHeight = window.innerHeight;
            var docHeight = document.documentElement.scrollHeight;
            var maxScroll = docHeight - winHeight;
            function updateBar() {
              var scrolled = window.scrollY;
              var pct = maxScroll > 0 ? (scrolled / maxScroll) * 100 : 0;
              bar.style.width = pct + '%';
            }
            window.addEventListener('scroll', updateBar, { passive: true });
            updateBar();
          }

          // Auto-generate TOC and anchor links
          var headings = document.querySelectorAll('h2, h3');
          headings.forEach(function(h) {
            if (!h.id) {
              h.id = h.textContent.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9\u4e00-\u9fff-]/g, '');
            }
            var anchor = document.createElement('a');
            anchor.href = '#' + h.id;
            anchor.className = 'anchor';
            anchor.textContent = '#';
            h.appendChild(anchor);
          });

          // Build inline TOC from h2/h3
          var h2s = document.querySelectorAll('h2');
          if (h2s.length >= 2) {
            var tocDiv = document.createElement('div');
            tocDiv.className = 'article-toc';
            var tocLabel = document.createElement('div');
            tocLabel.className = 'toc-label';
            tocLabel.textContent = '目录';
            tocDiv.appendChild(tocLabel);

            var main = document.querySelector('main');
            var firstH2 = h2s[0];

            var tocItems = [];
            h2s.forEach(function(h2) {
              tocItems.push({ el: h2, tag: 'h2' });
              var next = h2.nextElementSibling;
              while (next && next.tagName !== 'H2') {
                if (next.tagName === 'H3') {
                  tocItems.push({ el: next, tag: 'h3' });
                }
                next = next.nextElementSibling;
              }
            });

            tocItems.forEach(function(item) {
              var link = document.createElement('a');
              link.href = '#' + item.el.id;
              link.className = 'toc-' + item.tag;
              link.textContent = item.el.textContent.replace(/#$/, '').trim();
              tocDiv.appendChild(link);
            });

            main.insertBefore(tocDiv, firstH2);
          }
        }
      )()}
    </script>
  </body>
</html>
