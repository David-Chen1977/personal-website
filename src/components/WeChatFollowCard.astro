---
// 公众号关注卡片 — 用于文章底部
---

<div class="wechat-follow-card">
  <div class="wechat-follow-inner">
    <div class="wechat-qr-section">
      <img src="/images/qrcode-wechat.jpg" alt="道雷说道 公众号二维码" width="100" height="100" />
    </div>
    <div class="wechat-info-section">
      <div class="wechat-name">道雷说道</div>
      <div class="wechat-desc">每周推送投资框架与行业研究心得</div>
      <div class="wechat-benefits">
        <div class="benefit-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="3.5" fill="var(--accent)" fill-opacity="0.2"/><circle cx="7" cy="7" r="2" fill="var(--accent)"/></svg>
          <span>深度研究抢先看</span>
        </div>
        <div class="benefit-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="3.5" fill="var(--accent)" fill-opacity="0.2"/><circle cx="7" cy="7" r="2" fill="var(--accent)"/></svg>
          <span>每周更新通知</span>
        </div>
        <div class="benefit-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="3.5" fill="var(--accent)" fill-opacity="0.2"/><circle cx="7" cy="7" r="2" fill="var(--accent)"/></svg>
          <span>互动交流探讨</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .wechat-follow-card {
    margin: 2.5rem 0 1.5rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-card);
    background: var(--bg-card);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .wechat-follow-card:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .wechat-follow-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
  }
  .wechat-qr-section {
    flex-shrink: 0;
  }
  .wechat-qr-section img {
    width: 100px;
    height: 100px;
    border-radius: 6px;
    display: block;
  }
  .wechat-info-section {
    flex: 1;
    min-width: 0;
  }
  .wechat-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .wechat-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .wechat-benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
  }
</style>
