---
export interface Props {
  slug: string;
  title: string;
  desc: string;
  date: string;
  readTime: string;
  tag: string;
}

const { slug, title, desc, date, readTime, tag } = Astro.props;
---

<li class="article-card">
  <a href={`/blog/${slug}`} class="card-link">
    <div class="card-tag">{tag}</div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{desc}</p>
    <div class="card-meta">{date} · {readTime}</div>
  </a>
</li>

<style>
  .article-card {
    list-style: none;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-card);
    transition: all 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .article-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 50%, transparent));
    opacity: 0;
    transition: opacity 0.25s;
  }
  .article-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
  }
  .article-card:hover::before {
    opacity: 1;
  }
  .card-link {
    display: block;
    padding: 1.5rem 1.5rem 1.75rem;
    text-decoration: none;
    color: inherit;
  }
  .card-link:hover { text-decoration: none; }
  .card-tag {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }
  .card-title {
    font-size: 1.1rem;
    font-weight: 650;
    color: var(--text);
    line-height: 1.35;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }
  .article-card:hover .card-title {
    color: var(--accent);
  }
  .card-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
</style>
